  background-attachment: fixed;
  background-size: cover;
  background-repeat: no-repeat;
  border: none;
  padding: 5px;
  color: #d7e0de;
}

.toggled form,
.dynamic form {
  box-shadow: 0 0px 10px rgba(0, 0, 0, 0.34), 0 0px 10px rgba(0, 0, 0, 0.34),
    0 0px 10px rgba(0, 0, 0, 0.34), 0 0px 10px rgba(0, 0, 0, 0.34),
