  color: #879a9d;
  padding: 5px 7px;
}

dl.index dd {
  background-color: rgba( 0, 0, 0, 0.7);
  box-shadow: 0 0px 10px rgba(0, 0, 0, 0.34), 0 0px 10px rgba(0, 0, 0, 0.34),
    0 0px 10px rgba(0, 0, 0, 0.34), 0 0px 10px rgba(0, 0, 0, 0.34),
    0 0px 10px rgba(0, 0, 0, 0.34), 0 0px 10px rgba(0, 0, 0, 0.34);
}

.caution {
  color: #9cb5b5;
}

fieldset fieldset {
  background-color: rgba( 0, 0, 0, 0.5);
  color: #879a9d;
}

.post .required .warnings,
dd.required {
  color: #879a9d;
}

.required .autocomplete,
.autocomplete .notice {
  color: #879a9d;
}

.draft,
.draft .wrapper,
.unread,
.child,
.unwrangled,
.unreviewed {
  background-color: rgba( 0, 0, 0, 0.5);
}

.draft {
  border: 4px dashed #000;
  padding: 0.643em;
  border-radius: 0em;
}

.toggled form fieldset {
  background-image: url("https://64.media.tumblr.com/62b1b0b044ff968c7f51322ab5dc8120/4874c490d41c2e36-c4/s1280x1920/8c2969b6de0a0d2445bfebd1b11c5e986b1d5b3b.png");
